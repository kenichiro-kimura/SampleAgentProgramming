@page "/UserDetail/{id:int}"
@model SampleAgentProgramming.Pages.UserDetailModel
@{
    ViewData["Title"] = "利用者詳細";
}
<h1>利用者詳細</h1>
@if (Model.User != null)
{
    <table class="table">
        <tr><th>名前</th><td>@Model.User.Name</td></tr>
        <tr><th>所属会社</th><td>@Model.User.Company</td></tr>
        <tr><th>メールアドレス</th><td>@Model.User.Email</td></tr>
    </table>
    <a asp-page="/User" class="btn btn-secondary">一覧へ戻る</a>
}
else
{
    <p>利用者が見つかりません。</p>
    <a asp-page="/User" class="btn btn-secondary">一覧へ戻る</a>
}
