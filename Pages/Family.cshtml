@page
@model FamilyModel
@{
    ViewData["Title"] = "家族一覧";
}

<div class="row">
    <div class="col-md-12">
        <h1>@ViewData["Title"]</h1>
        
        <div class="mb-3">
            <a asp-area="" asp-page="/Index" class="btn btn-secondary">ホームに戻る</a>
        </div>

        <div class="row">
            <div class="col-md-8">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>名前</th>
                            <th>続柄</th>
                            <th>メールアドレス</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in Model.FamilyMembers)
                        {
                            <tr>
                                <td>
                                    <a asp-area="" asp-page="/FamilyDetail" asp-route-id="@member.Id" class="text-primary">
                                        @member.Name
                                    </a>
                                </td>
                                <td>@member.Relationship</td>
                                <td>@member.MaskedEmail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>